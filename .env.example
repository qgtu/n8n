# ============================================
# n8n Configuration File - Example
# Copy this file to ".env" and fill in real values.
# ============================================

# ------------------------------
# Server Settings
# ------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Base URL & Webhook
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/

# ------------------------------
# Database (PostgreSQL)
# ------------------------------
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=disciplined_travel
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=your_postgres_password

# ------------------------------
# Timezone & Locale
# ------------------------------
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh
DEFAULT_LOCALE=vi

# ------------------------------
# Execution Settings
# ------------------------------
EXECUTIONS_MODE=regular
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true
EXECUTIONS_DATA_SAVE_ON_PROGRESS=true

# ------------------------------
# Security
# ------------------------------
N8N_BASIC_AUTH_ACTIVE=false

# ------------------------------
# Logging
# ------------------------------
N8N_LOG_LEVEL=debug
N8N_LOG_OUTPUT=console,file
N8N_LOG_FILE_LOCATION=C:/Users/Admin/Desktop/n8n/logs
N8N_LOG_FILE_SIZE_MAX=20
N8N_LOG_FILE_COUNT_MAX=7

# ------------------------------
# Community Nodes
# ------------------------------
N8N_COMMUNITY_PACKAGES_ENABLED=true

# ------------------------------
# Development
# ------------------------------
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=true

# ------------------------------
# API Keys (Travel Bot Workflow)
# ------------------------------
ORS_API_KEY=your_ors_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
WEATHER_API_KEY=your_weather_api_key
HERE_API_KEY=your_here_api_key
# SERP_API_KEY=your_serp_api_key

# ------------------------------
# Telegram
# ------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=
TELEGRAM_SECRET_TOKEN=your_telegram_secret_token
